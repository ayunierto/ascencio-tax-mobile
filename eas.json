{
  "cli": {
    "version": ">= 16.26.0",
    "appVersionSource": "remote",
    "requireCommit": false
  },
  "build": {
    "development": {
      "ios": {
        "simulator": true
      },
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "NODE_ENV": "production"
      }
    },
    "simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "platforms": ["ios"]
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6755322765"
      }
    }
  }
}
